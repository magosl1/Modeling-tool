# Database
POSTGRES_DB=financial_modeler
POSTGRES_USER=fm_user
POSTGRES_PASSWORD=change-me-locally
DATABASE_URL=postgresql://fm_user:change-me-locally@localhost:5432/financial_modeler

# Auth / JWT
# REQUIRED. Minimum 32 characters. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# CORS — comma-separated list of allowed frontend origins.
# Required (without localhost entries) when DEBUG=false.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# AWS (optional, for S3 uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=financial-modeler-uploads

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Runtime
DEBUG=false
