# Database
POSTGRES_DB=financial_modeler
POSTGRES_USER=fm_user
POSTGRES_PASSWORD=change-me-locally
DATABASE_URL=postgresql://fm_user:change-me-locally@localhost:5432/financial_modeler

# Auth / JWT
SECRET_KEY=change-me-in-production-use-a-long-random-string

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# AWS (optional, for S3 uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=financial-modeler-uploads

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Runtime
DEBUG=false
